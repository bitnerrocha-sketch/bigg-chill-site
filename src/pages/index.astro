---
const giftCardLink = "https://app.squareup.com/gift/MLQY19DJP25AS/order";

const heroSlides = [
  {
    image: "/hero-flavor-1.JPG",
    label: "Featured Flavor",
    flavor: "Strawberry Cheesecake",
    note: "Creamy, fruity & oh-so dreamy.",
  },
  {
    image: "/hero-flavor-2.JPG",
    label: "Small-Batch Favorite",
    flavor: "Cookie Dough",
    note: "A classic scoop made the Bigg Chill way.",
  },
  {
    image: "/hero-flavor-3.JPG",
    label: "Rotating Monthly",
    flavor: "Seasonal Scoops",
    note: "New flavors worth coming back for.",
  },
  {
    image: "/hero-flavor-4.JPG",
    label: "Made In Cody",
    flavor: "Handcrafted Ice Cream",
    note: "Fresh, thoughtful, and made with care.",
  },
  {
    image: "/hero-flavor-5.JPG",
    label: "Fan Favorite",
    flavor: "Bigg Chill Classics",
    note: "The flavors people ask for again and again.",
  },
];

const flavors = [
  "Vanilla Bean",
  "Strawberry Honey Balsamic",
  "White Chocolate Huckleberry",
  "Honey Comb",
  "Mint Chocolate Chunk",
  "Midnight Cookies",
  "Chocolate Brownie",
  "Birthday Cake",
  "Coffee",
  "Mixed Berry Tart",
  "Biscoff Cheesecake",
  "Coffee Maple Bar",
  "Raspberry Fudge",
  "Lemon Raspberry",
  "Stuffed PB Cup",
  "Dubai Chocolate Bar",
  "Bourbon Maple Pecan",
  "Tequila Keylime Pie",
  "Cookie Monster",
];

const tickerFlavors = [...flavors, ...flavors];
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>The Bigg Chill | Handcrafted Ice Cream in Cody, Wyoming</title>
    <meta
      name="description"
      content="The Bigg Chill serves handcrafted small-batch ice cream in Cody, Wyoming with rotating flavors, gift cards, catering, and a love for the local community."
    />

    <link
      href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:ital,wght@0,700;0,800;0,900;1,800;1,900&family=Pacifico&family=Oswald:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />

    <style>
      :root {
        --teal: #365b6d;
        --coral: #ea605f;
        --cream: #ffece0;
        --cream-light: #fff8ef;
        --pink-soft: #feb9e3;
        --pink-hot: #fe019b;
        --pink-muted: #f5c6c8;
        --lavender: #9a86a4;
        --white: #ffffff;
        --black: #000000;
        --shadow: 0 18px 45px rgba(54, 91, 109, 0.14);
        --border: rgba(54, 91, 109, 0.28);
      }

      * {
        box-sizing: border-box;
      }

      body {
        margin: 0;
        font-family: "Oswald", sans-serif;
        color: var(--teal);
        background:
          radial-gradient(circle at top left, rgba(254, 185, 227, 0.22), transparent 32%),
          linear-gradient(180deg, #fff8ef 0%, #ffece0 52%, #fff8ef 100%);
      }

      img {
        max-width: 100%;
        display: block;
      }

      a {
        color: inherit;
      }

      .page-shell {
        background-image:
          linear-gradient(rgba(54, 91, 109, 0.035) 1px, transparent 1px),
          linear-gradient(90deg, rgba(54, 91, 109, 0.035) 1px, transparent 1px);
        background-size: 34px 34px;
      }

      /* NAV */
      .nav {
        background: var(--cream-light);
        border-bottom: 4px solid var(--coral);
        padding: 6px clamp(18px, 5vw, 76px);
        display: flex;
        align-items: center;
        justify-content: space-between;
        position: sticky;
        top: 0;
        z-index: 100;
      }

      .brand {
  text-decoration: none;
  display: inline-flex;
  align-items: center;
  width: 340px;
  height: 135px;
  overflow: hidden;
}

.nav-logo {
  width: 340px;
  height: auto;
  display: block;
  transform: translateY(10px);
}

      .brand-script {
        font-family: "Pacifico", cursive;
        font-size: 1.15rem;
        margin-left: 38px;
        margin-bottom: -7px;
      }

      .brand-main {
        font-family: "Barlow Condensed", sans-serif;
        font-size: clamp(2.1rem, 4vw, 3.4rem);
        font-weight: 900;
        text-transform: uppercase;
        font-style: italic;
        letter-spacing: 1px;
        line-height: 0.85;
      }

      .brand-tag {
        font-size: 0.78rem;
        letter-spacing: 1.5px;
        text-transform: uppercase;
        margin-top: 4px;
        color: var(--coral);
      }

      .desktop-links {
        display: flex;
        align-items: center;
        gap: clamp(22px, 3vw, 42px);
      }

      .desktop-links a {
        font-family: "Barlow Condensed", sans-serif;
        text-decoration: none;
        text-transform: uppercase;
        font-size: 1.1rem;
        font-weight: 900;
        letter-spacing: 1.3px;
        color: var(--teal);
        position: relative;
      }

      .desktop-links a.active,
      .desktop-links a:hover {
        color: var(--coral);
      }

      .desktop-links a.active::after {
        content: "";
        position: absolute;
        left: 0;
        right: 0;
        bottom: -8px;
        height: 3px;
        background: var(--coral);
        border-radius: 999px;
      }

      .menu-toggle {
        display: none;
        background: none;
        border: none;
        color: var(--teal);
        font-size: 2.5rem;
        cursor: pointer;
      }

      .mobile-menu {
        position: fixed;
        inset: 0;
        background: var(--cream-light);
        z-index: 999;
        display: none;
        flex-direction: column;
        align-items: center;
        justify-content: center;
      }

      .mobile-menu.open {
        display: flex;
      }

      .close-menu {
        position: absolute;
        top: 28px;
        right: 32px;
        background: none;
        border: none;
        color: var(--teal);
        font-size: 3rem;
        cursor: pointer;
      }

      .mobile-links {
        display: flex;
        flex-direction: column;
        gap: 32px;
        text-align: center;
      }

      .mobile-links a {
  color: var(--teal);
  text-decoration: none;
  font-family: "Oswald", sans-serif;
  font-size: 1.5rem;
  font-weight: 400;
  letter-spacing: 8px;
  text-transform: uppercase;
}

      .mobile-links a:hover {
        color: var(--coral);
      }

      /* GLOBAL COMPONENTS */
      .retro-frame {
        border: 2px solid rgba(234, 96, 95, 0.5);
        border-radius: 22px;
        position: relative;
        box-shadow: inset 0 0 0 6px rgba(255, 248, 239, 0.55);
      }

      .script {
        font-family: "Pacifico", cursive;
        color: var(--coral);
        font-weight: 400;
      }

      .section-kicker {
        font-family: "Pacifico", cursive;
        color: var(--coral);
        font-size: clamp(1.25rem, 2.3vw, 1.8rem);
        margin: 0 0 4px;
      }

      .section-title {
        font-family: "Barlow Condensed", sans-serif;
        text-transform: uppercase;
        font-size: clamp(2.4rem, 5vw, 4.6rem);
        line-height: 0.9;
        letter-spacing: 4px;
        margin: 0;
        color: var(--teal);
      }

      .btn {
        font-family: "Barlow Condensed", sans-serif;
        background: var(--coral);
        color: var(--white);
        padding: 13px 24px;
        text-decoration: none;
        border-radius: 8px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-weight: 900;
        text-transform: uppercase;
        letter-spacing: 1.5px;
        border: 2px solid var(--coral);
        box-shadow: 0 5px 0 rgba(151, 63, 63, 0.35);
        transition: 0.2s ease;
      }

      .btn:hover {
        transform: translateY(-2px);
        box-shadow: 0 7px 0 rgba(151, 63, 63, 0.3);
      }

      .btn-outline {
        background: var(--cream-light);
        color: var(--teal);
        border-color: var(--teal);
        box-shadow: 0 5px 0 rgba(54, 91, 109, 0.22);
      }

      .divider {
        max-width: 1120px;
        margin: 0 auto;
        height: 1px;
        background: linear-gradient(90deg, transparent, rgba(234, 96, 95, 0.42), transparent);
      }

      /* HERO */
      .hero {
        padding: clamp(18px, 3vw, 34px) clamp(16px, 4vw, 54px) 30px;
      }

      .hero-slider {
        max-width: 1240px;
        min-height: 620px;
        margin: 0 auto;
        overflow: hidden;
        background: var(--pink-muted);
        display: grid;
        grid-template-columns: 0.85fr 1.15fr;
        align-items: stretch;
      }

      .hero-copy {
        position: relative;
        z-index: 2;
        padding: clamp(32px, 5vw, 68px);
        display: flex;
        flex-direction: column;
        justify-content: center;
        background:
          radial-gradient(circle at 20% 30%, rgba(255, 255, 255, 0.42), transparent 28%),
          linear-gradient(90deg, rgba(255, 236, 224, 0.95), rgba(245, 198, 200, 0.78));
      }

      .hero-copy h1 {
        margin: 0;
      }

      .hero-copy .script {
        display: block;
        font-size: clamp(1.9rem, 3.4vw, 3.1rem);
        margin-bottom: 8px;
      }

      .hero-main {
        font-family: "Barlow Condensed", sans-serif;
        display: block;
        font-size: clamp(3.9rem, 7.5vw, 7.4rem);
        line-height: 0.82;
        text-transform: uppercase;
        font-weight: 900;
        letter-spacing: 3px;
        color: var(--teal);
      }

      .hero-memory {
        font-family: "Pacifico", cursive;
        display: block;
        font-size: clamp(2.8rem, 5.5vw, 5.4rem);
        line-height: 0.95;
        color: var(--teal);
        margin-top: 6px;
      }

      .hero-starline {
        display: flex;
        align-items: center;
        gap: 14px;
        color: var(--coral);
        margin: 24px 0 18px;
      }

      .hero-starline::before,
      .hero-starline::after {
        content: "";
        width: 72px;
        height: 2px;
        background: rgba(234, 96, 95, 0.48);
      }

      .hero-copy p {
        max-width: 500px;
        font-size: clamp(1rem, 1.4vw, 1.18rem);
        line-height: 1.55;
        margin: 0 0 24px;
        color: #264957;
      }

      .hero-buttons {
        display: flex;
        flex-wrap: wrap;
        gap: 13px;
      }

      .hero-photo {
        position: relative;
        min-height: 620px;
        overflow: hidden;
        background: #f5c6c8;
      }

      .hero-slide {
        position: absolute;
        inset: 0;
        opacity: 0;
        transition: opacity 900ms ease;
      }

      .hero-slide.active {
        opacity: 1;
      }

      .hero-slide img {
        width: 100%;
        height: 100%;
        object-fit: cover;
      }

      .hero-photo::after {
        content: "";
        position: absolute;
        inset: 0;
        background:
          linear-gradient(90deg, rgba(255, 236, 224, 0.34), transparent 32%),
          radial-gradient(circle at 50% 50%, transparent 35%, rgba(54, 91, 109, 0.08));
        pointer-events: none;
      }

      .slide-label {
  display: none;
  position: absolute;
  right: clamp(18px, 4vw, 44px);
  bottom: clamp(22px, 4vw, 46px);
  z-index: 3;
  background: rgba(255, 248, 239, 0.94);
  border: 2px solid rgba(54, 91, 109, 0.28);
  box-shadow: var(--shadow);
  border-radius: 10px;
  padding: 18px 22px;
  min-width: min(330px, calc(100% - 36px));
  text-align: center;
}

      .slide-label small {
        display: block;
        font-family: "Barlow Condensed", sans-serif;
        text-transform: uppercase;
        color: var(--teal);
        letter-spacing: 2px;
        font-weight: 900;
        margin-bottom: 4px;
      }

      .slide-label strong {
        display: block;
        font-family: "Barlow Condensed", sans-serif;
        color: var(--teal);
        font-size: 1.7rem;
        line-height: 0.95;
        text-transform: uppercase;
        letter-spacing: 1px;
      }

      .slide-label span {
        display: block;
        font-family: "Pacifico", cursive;
        color: var(--coral);
        font-size: 1rem;
        margin-top: 6px;
      }

      .hero-arrow {
        position: absolute;
        top: 50%;
        transform: translateY(-50%);
        z-index: 4;
        width: 46px;
        height: 46px;
        border-radius: 999px;
        border: 2px solid rgba(54, 91, 109, 0.25);
        background: rgba(255, 248, 239, 0.88);
        color: var(--teal);
        font-size: 2rem;
        line-height: 1;
        cursor: pointer;
        display: grid;
        place-items: center;
      }

      .hero-arrow:hover {
        background: var(--white);
      }

      .hero-arrow.prev {
        left: 18px;
      }

      .hero-arrow.next {
        right: 18px;
      }

      .hero-dots {
        position: absolute;
        left: 50%;
        bottom: 18px;
        transform: translateX(-50%);
        display: flex;
        gap: 10px;
        z-index: 5;
      }

      .hero-dot {
        width: 11px;
        height: 11px;
        padding: 0;
        border-radius: 999px;
        border: 2px solid var(--teal);
        background: transparent;
        cursor: pointer;
      }

      .hero-dot.active {
        background: var(--teal);
      }

      /* INTRO */
      .intro {
        padding: 28px 20px 34px;
        text-align: center;
        background: rgba(255, 248, 239, 0.82);
      }

      .intro p {
        max-width: 760px;
        margin: 8px auto 0;
        font-size: 1.1rem;
        line-height: 1.55;
        color: #264957;
      }

      /* OUR STORY */
.our-story {
  padding: clamp(54px, 7vw, 92px) clamp(16px, 4vw, 54px);
  background:
    radial-gradient(circle at 18% 22%, rgba(254, 1, 155, 0.18), transparent 28%),
    radial-gradient(circle at 82% 72%, rgba(254, 185, 227, 0.32), transparent 32%),
    linear-gradient(180deg, #fff6fb 0%, #ffe4f3 48%, #fff7fb 100%);
}

.our-story-inner {
  max-width: 1240px;
  margin: 0 auto;
  padding: clamp(28px, 5vw, 54px);
  background:
    linear-gradient(180deg, rgba(255, 255, 255, 0.62), rgba(255, 230, 245, 0.56)),
    #fff7fb;
  border: 2px solid rgba(254, 1, 155, 0.5);
  border-radius: 26px;
  box-shadow:
    0 28px 70px rgba(54, 91, 109, 0.11),
    inset 0 0 0 7px rgba(255, 255, 255, 0.4);
  position: relative;
  overflow: hidden;
}

.our-story-inner::before {
  content: "";
  position: absolute;
  inset: 14px;
  border: 1px solid rgba(254, 1, 155, 0.28);
  border-radius: 20px;
  pointer-events: none;
}

.story-label-wrap {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 22px;
  margin-bottom: 14px;
  position: relative;
  z-index: 1;
}

.story-line {
  width: clamp(48px, 8vw, 92px);
  height: 1px;
  background: rgba(254, 1, 155, 0.68);
}

.story-label {
  margin: 0;
  font-family: "Barlow Condensed", sans-serif;
  text-transform: uppercase;
  color: var(--pink-hot);
  letter-spacing: 5px;
  font-size: clamp(1.15rem, 2vw, 1.55rem);
  font-weight: 700;
}

.our-story-title {
  position: relative;
  z-index: 1;
  margin: 0 0 clamp(34px, 5vw, 56px);
  text-align: center;
  font-family: Georgia, "Times New Roman", serif;
  font-size: clamp(3rem, 7vw, 6.6rem);
  line-height: 0.92;
  letter-spacing: 3px;
  font-weight: 400;
  color: #1f3d4d;
  text-transform: uppercase;
}

.story-layout {
  position: relative;
  z-index: 1;
  display: grid;
  grid-template-columns: 1fr 0.78fr 1fr;
  gap: clamp(24px, 4vw, 44px);
  align-items: start;
}

.story-left,
.story-right {
  display: grid;
  gap: clamp(24px, 3vw, 34px);
}

.story-photo {
  width: 100%;
  object-fit: cover;
  border: 2px solid rgba(254, 1, 155, 0.62);
  border-radius: 22px;
  box-shadow: 0 18px 38px rgba(54, 91, 109, 0.14);
  background: #fff;
}

.story-photo-family {
  height: clamp(280px, 32vw, 380px);
}

.story-photo-machine {
  height: clamp(260px, 29vw, 355px);
}

.story-photo-shop {
  height: clamp(290px, 34vw, 405px);
}

.story-copy {
  padding-top: 6px;
  color: #233f4d;
}

.story-copy p {
  margin: 0 0 24px;
  font-family: Georgia, "Times New Roman", serif;
  font-size: clamp(1rem, 1.4vw, 1.22rem);
  line-height: 1.62;
}

.story-copy p:last-child {
  margin-bottom: 0;
}

.story-copy span {
  color: var(--pink-hot);
  font-style: italic;
}

.copy-divider {
  width: 112px;
  height: 1px;
  margin: 28px auto 28px;
  background: linear-gradient(
    90deg,
    transparent,
    rgba(254, 1, 155, 0.68),
    transparent
  );
  position: relative;
}

.copy-divider::after {
  content: "✦";
  position: absolute;
  left: 50%;
  top: 50%;
  transform: translate(-50%, -52%);
  background: #fff7fb;
  color: var(--pink-hot);
  padding: 0 10px;
  font-size: 0.85rem;
}

.story-quote-box {
  min-height: clamp(260px, 28vw, 350px);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background:
    radial-gradient(circle at 50% 0%, rgba(255, 255, 255, 0.78), transparent 48%),
    linear-gradient(180deg, #ffd7ec, #fff0f8);
  border: 2px solid rgba(254, 1, 155, 0.48);
  border-radius: 24px;
  padding: clamp(26px, 4vw, 44px);
  text-align: center;
  box-shadow: 0 18px 38px rgba(54, 91, 109, 0.1);
}

.story-quote-box p {
  margin: 0;
  font-family: Georgia, "Times New Roman", serif;
  font-size: clamp(1.85rem, 3vw, 3.2rem);
  line-height: 1.15;
  font-style: italic;
  color: var(--pink-hot);
}

.quote-mark {
  font-family: Georgia, "Times New Roman", serif;
  color: var(--pink-hot);
  font-size: clamp(2.2rem, 4vw, 4rem);
  line-height: 0.75;
  opacity: 0.8;
}

      /* FLAVOR TICKER */
      .flavors {
        padding: 36px 0 44px;
        background: rgba(255, 236, 224, 0.75);
        overflow: hidden;
      }

      .flavor-heading {
        text-align: center;
        margin-bottom: 18px;
      }

      .ticker-shell {
        position: relative;
        overflow: hidden;
        border-top: 1px solid rgba(234, 96, 95, 0.35);
        border-bottom: 1px solid rgba(234, 96, 95, 0.35);
        padding: 18px 0;
        background: rgba(255, 248, 239, 0.68);
      }

      .ticker-track {
        display: flex;
        width: max-content;
        gap: 18px;
        animation: ticker 34s linear infinite;
      }

      .ticker-shell:hover .ticker-track {
        animation-play-state: paused;
      }

      .flavor-pill {
        min-width: max-content;
        padding: 13px 28px;
        background: var(--cream-light);
        border: 2px solid rgba(54, 91, 109, 0.42);
        border-radius: 10px;
        box-shadow: 0 5px 0 rgba(54, 91, 109, 0.12);
        font-family: "Barlow Condensed", sans-serif;
        font-weight: 900;
        text-transform: uppercase;
        letter-spacing: 1.2px;
        color: var(--teal);
      }

      @keyframes ticker {
        from {
          transform: translateX(0);
        }
        to {
          transform: translateX(-50%);
        }
      }

      .flavor-cta {
        text-align: center;
        margin-top: 24px;
      }

      /* VISIT */
      .visit {
        padding: 54px 20px;
      }

      .visit-inner {
        max-width: 1160px;
        margin: 0 auto;
        padding: clamp(24px, 4vw, 42px);
        background: rgba(255, 248, 239, 0.85);
        display: grid;
        grid-template-columns: 0.8fr 1.05fr 0.8fr;
        gap: 30px;
        align-items: center;
      }

      .visit-copy p {
        font-size: 1.05rem;
        line-height: 1.55;
        color: #264957;
        margin: 14px 0 22px;
      }

      .visit-photo img {
        width: 100%;
        height: 280px;
        object-fit: cover;
        border-radius: 16px;
        border: 2px solid rgba(54, 91, 109, 0.2);
        box-shadow: var(--shadow);
      }

      .visit-info {
        display: grid;
        gap: 18px;
      }

      .info-row {
        display: grid;
        grid-template-columns: 42px 1fr;
        gap: 14px;
        align-items: start;
      }

      .info-icon {
        width: 42px;
        height: 42px;
        border-radius: 999px;
        border: 2px solid var(--coral);
        color: var(--coral);
        display: grid;
        place-items: center;
        font-size: 1.3rem;
      }

      .info-row h3 {
        margin: 0 0 4px;
        font-family: "Barlow Condensed", sans-serif;
        text-transform: uppercase;
        letter-spacing: 1px;
        font-size: 1.25rem;
        color: var(--teal);
      }

      .info-row p {
        margin: 0;
        color: #264957;
        line-height: 1.4;
      }

      /* GIFT CARD */
      .gift {
        padding: 22px 20px 46px;
      }

      .gift-inner {
        max-width: 1160px;
        margin: 0 auto;
        padding: clamp(28px, 4vw, 44px);
        background:
          radial-gradient(circle at 85% 50%, rgba(255, 255, 255, 0.55), transparent 23%),
          linear-gradient(90deg, var(--pink-muted), var(--pink-soft));
        display: grid;
        grid-template-columns: 0.85fr 1.2fr 0.7fr;
        gap: 28px;
        align-items: center;
        overflow: hidden;
      }

      .gift-card-graphic {
        background: var(--cream-light);
        color: var(--coral);
        border: 2px solid rgba(54, 91, 109, 0.22);
        border-radius: 14px;
        padding: 28px 20px;
        text-align: center;
        transform: rotate(-5deg);
        box-shadow: var(--shadow);
        max-width: 290px;
        margin: 0 auto;
      }

