---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>Current Ice Cream Flavors in Cody, WY | The Bigg Chill</title>
    <meta
      name="description"
      content="Explore The Bigg Chill's rotating monthly menu of handcrafted ice cream flavors, seasonal scoops, dairy-free options, and small-batch ice cream in Cody, Wyoming."
    />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
  href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:ital,wght@0,700;0,800;0,900;1,800;1,900&family=Cooper+Black&family=Oswald:wght@400;500;600;700&family=Pacifico&family=Nunito:wght@400;600;700;800;900&display=swap"
  rel="stylesheet"
/>

    <style is:global>
      :root {
        --bigg-blue: #365b6d;
        --bigg-coral: #ea605f;
        --bigg-cream: #ffece0;
        --bigg-soft-cream: #f8f4eb;
        --bigg-pink: #f0a1a5;
        --bigg-light-pink: #f5c6c8;
        --bigg-lavender: #9a86a4;
        --bigg-white: #ffffff;
        --bigg-ink: #213946;
      }

      html,
      body {
        margin: 0 !important;
        padding: 0 !important;
        background: var(--bigg-soft-cream) !important;
      }

      body {
        font-family: "Nunito", Arial, sans-serif !important;
      }

      .bigg-menu-page,
      .bigg-menu-page * {
        box-sizing: border-box;
      }

      .bigg-menu-page {
        width: 100%;
        min-height: 100vh;
        overflow: hidden;
        background:
          radial-gradient(circle at 10% 12%, rgba(240, 161, 165, 0.16), transparent 24%),
          radial-gradient(circle at 90% 4%, rgba(245, 198, 200, 0.28), transparent 20%),
          var(--bigg-soft-cream) !important;
        color: var(--bigg-blue) !important;
        font-family: "Nunito", Arial, sans-serif !important;
      }

      .bigg-menu-page a {
        color: inherit !important;
      }

      .bigg-menu-page .site-nav {
  width: 100%;
  background: var(--bigg-soft-cream) !important;
  border-bottom: 4px solid var(--bigg-coral) !important;
  padding: 6px clamp(18px, 5vw, 76px) !important;
}

.bigg-menu-page .site-nav-inner {
  width: 100%;
  margin: 0;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24px;
}

.bigg-menu-page .site-brand {
  text-decoration: none !important;
  display: inline-flex;
  align-items: center;
  width: 340px;
  height: 135px;
  overflow: hidden;
  transform: none;
}

.bigg-menu-page .site-logo-img {
  width: 273px;
  height: auto;
  object-fit: contain;
  display: block;
  transform: translateY(10px);
  transform-origin: center;
}
      .bigg-menu-page .site-brand-main {
        color: var(--bigg-blue) !important;
        font-family: "Pacifico", cursive !important;
        font-size: clamp(2rem, 4vw, 3rem) !important;
        font-weight: 400 !important;
        line-height: 1 !important;
        text-transform: none !important;
        font-style: normal !important;
        letter-spacing: 0.01em !important;
      }

      .bigg-menu-page .site-brand-sub {
        margin-top: 7px;
        color: var(--bigg-coral) !important;
        font-family: "Oswald", Arial, sans-serif !important;
        font-size: 0.72rem !important;
        font-weight: 700 !important;
        text-transform: uppercase !important;
        letter-spacing: 0.26em !important;
        text-align: center;
      }

      .bigg-menu-page .site-nav-links {
  display: flex;
  align-items: center;
  gap: clamp(22px, 3vw, 42px);
}

.bigg-menu-page .site-nav-links a {
  font-family: "Barlow Condensed", Arial, sans-serif !important;
  color: var(--bigg-blue) !important;
  text-decoration: none !important;
  text-transform: uppercase;
  font-size: 1.1rem;
  font-weight: 900;
  letter-spacing: 1.3px;
  position: relative;
}

.bigg-menu-page .site-nav-links a:hover {
  color: var(--bigg-coral) !important;
}

.bigg-menu-page .site-nav-links a.active {
  color: var(--bigg-coral) !important;
}

.bigg-menu-page .site-nav-links a.active::after {
  content: "";
  position: absolute;
  left: 0;
  right: 0;
  bottom: -8px;
  height: 3px;
  background: var(--bigg-coral);
  border-radius: 999px;
}

      .bigg-menu-page .mobile-menu-icon {
        display: none;
        width: 42px;
      }

      .bigg-menu-page .mobile-menu-icon span {
        display: block;
        width: 100%;
        height: 4px;
        margin-bottom: 8px;
        border-radius: 999px;
        background: var(--bigg-blue);
        transition: transform 0.2s ease, opacity 0.2s ease;
      }

      .bigg-menu-page .hero {
  position: relative;
  isolation: isolate;
  width: 100%;
  padding: 78px 24px 110px !important;
  background:
    linear-gradient(rgba(245, 198, 200, 0.48), rgba(245, 198, 200, 0.48)),
    url("/sprinkles-bg.png") center / cover no-repeat,
    linear-gradient(180deg, #f8cbd4 0%, var(--bigg-light-pink) 100%) !important;
  color: var(--bigg-blue) !important;
  text-align: center !important;
}

      .bigg-menu-page .hero::after {
  display: none;
}

      .bigg-menu-page .sprinkle {
  display: none;
}

      .bigg-menu-page .sprinkle-1 {
        left: 8%;
        top: 34%;
        transform: rotate(-28deg);
      }

      .bigg-menu-page .sprinkle-2 {
        left: 13%;
        top: 22%;
        transform: rotate(34deg);
      }

      .bigg-menu-page .sprinkle-3 {
        right: 10%;
        top: 30%;
        transform: rotate(26deg);
      }

      .bigg-menu-page .sprinkle-4 {
        right: 7%;
        top: 20%;
        transform: rotate(-35deg);
      }

      .bigg-menu-page .hero h1 {
        margin: 0 !important;
        color: var(--bigg-blue) !important;
        font-family: "Pacifico", cursive !important;
        font-size: clamp(4.3rem, 11vw, 8.2rem) !important;
        font-weight: 400 !important;
        line-height: 0.95 !important;
        text-transform: capitalize !important;
        letter-spacing: 0 !important;
        font-style: normal !important;
      }

      .bigg-menu-page .hero-copy {
        max-width: 820px;
        margin: 26px auto 0 !important;
        color: var(--bigg-blue) !important;
        font-family: "Nunito", Arial, sans-serif !important;
        font-size: clamp(1.15rem, 2.1vw, 1.55rem) !important;
        font-weight: 800 !important;
        line-height: 1.36 !important;
      }

      .bigg-menu-page .hero-kicker {
        margin-top: 30px;
        color: var(--bigg-coral) !important;
        font-family: "Oswald", Arial, sans-serif !important;
        font-size: clamp(0.82rem, 1.5vw, 1.05rem) !important;
        font-weight: 700 !important;
        text-transform: uppercase !important;
        letter-spacing: 0.23em !important;
      }

      .bigg-menu-page .container {
        width: min(1120px, calc(100% - 36px));
        margin: 0 auto;
      }

      .bigg-menu-page .feature-pills {
  position: relative;
  z-index: 3;
  display: grid !important;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  gap: 18px;
  margin: 34px auto 30px;
}

      .bigg-menu-page .feature-pill {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        min-height: 54px;
        padding: 12px 16px;
        border: 2px solid rgba(54, 91, 109, 0.38);
        border-radius: 999px;
        background: rgba(255, 255, 255, 0.58);
        color: var(--bigg-blue);
        font-family: "Pacifico", cursive;
        font-size: 1.03rem;
        line-height: 1;
        box-shadow: 0 8px 24px rgba(54, 91, 109, 0.06);
      }

      .bigg-menu-page .feature-pill strong {
        color: var(--bigg-coral);
        font-family: "Nunito", Arial, sans-serif;
        font-size: 1.05rem;
      }

      .bigg-menu-page .filters {
        display: flex !important;
        flex-wrap: wrap;
        justify-content: center;
        gap: 16px;
        padding: 24px 0 34px;
        border-top: 1px solid rgba(54, 91, 109, 0.12);
        border-bottom: 1px solid rgba(54, 91, 109, 0.12);
      }

      .bigg-menu-page .filter-btn {
        appearance: none !important;
        border: 2px solid rgba(54, 91, 109, 0.52) !important;
        background: transparent !important;
        color: var(--bigg-blue) !important;
        padding: 11px 28px !important;
        border-radius: 999px !important;
        font-family: "Pacifico", cursive !important;
        font-size: 1.02rem !important;
        line-height: 1 !important;
        cursor: pointer;
        box-shadow: none !important;
      }

      .bigg-menu-page .filter-btn.is-active,
      .bigg-menu-page .filter-btn:hover {
        background: var(--bigg-blue) !important;
        color: var(--bigg-white) !important;
      }
.bigg-menu-page .collection-section {
  margin: 42px 0 34px;
}

.bigg-menu-page .collection-heading {
  text-align: center;
  margin-bottom: 28px;
}

.bigg-menu-page .collection-heading span {
  display: block;
  color: var(--bigg-coral);
  font-family: "Pacifico", cursive;
  font-size: 1.75rem;
  line-height: 1;
  margin-bottom: 6px;
}

.bigg-menu-page .collection-heading h2 {
  margin: 0;
  color: var(--bigg-blue);
  font-family: "Oswald", Arial, sans-serif;
  font-size: clamp(2rem, 4vw, 3.1rem);
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.18em;
}

.bigg-menu-page .collection-heading p {
  margin: 8px 0 0;
  color: var(--bigg-ink);
  font-family: "Nunito", Arial, sans-serif;
  font-size: 1.05rem;
  font-weight: 800;
}

.bigg-menu-page .collection-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 24px;
}

.bigg-menu-page .collection-card {
  display: grid;
  grid-template-columns: 150px 1fr;
  gap: 24px;
  align-items: center;
  min-height: 255px;
  padding: 28px;
  border-radius: 24px;
  border: 2px solid rgba(234, 96, 95, 0.28);
  box-shadow: 0 14px 32px rgba(54, 91, 109, 0.06);
}

.bigg-menu-page .collection-classics {
  background: linear-gradient(135deg, rgba(255, 236, 224, 0.78), rgba(255, 255, 255, 0.6));
}

.bigg-menu-page .collection-limited {
  background: linear-gradient(135deg, rgba(245, 198, 200, 0.48), rgba(255, 255, 255, 0.62));
}

.bigg-menu-page .collection-dairy {
  background: linear-gradient(135deg, rgba(54, 91, 109, 0.1), rgba(255, 255, 255, 0.62));
  border-color: rgba(154, 134, 164, 0.45);
}

.bigg-menu-page .collection-boozy {
  background: linear-gradient(135deg, rgba(255, 236, 224, 0.7), rgba(240, 161, 165, 0.22));
}

.bigg-menu-page .collection-art {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 132px;
  height: 132px;
  border-radius: 999px;
  background: rgba(255, 255, 255, 0.58);
  color: var(--bigg-blue);
  font-size: 4.5rem;
  filter: grayscale(0.35);
}

.bigg-menu-page .collection-copy h3 {
  margin: 0 0 16px;
  color: var(--bigg-blue);
  font-family: "Oswald", Arial, sans-serif;
  font-size: clamp(1.35rem, 2.3vw, 1.85rem);
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.2em;
}

.bigg-menu-page .collection-copy h3::after {
  content: "";
  display: block;
  width: 100%;
  max-width: 310px;
  margin-top: 12px;
  border-top: 4px dotted var(--bigg-coral);
}

.bigg-menu-page .collection-copy p {
  margin: 0;
  color: var(--bigg-ink);
  font-family: "Nunito", Arial, sans-serif;
  font-size: 1rem;
  font-weight: 800;
  line-height: 1.48;
}

@media (max-width: 900px) {
  .bigg-menu-page .collection-grid {
    grid-template-columns: 1fr;
  }

  .bigg-menu-page .collection-card {
    grid-template-columns: 120px 1fr;
  }

  .bigg-menu-page .collection-art {
    width: 110px;
    height: 110px;
    font-size: 3.8rem;
  }
}

@media (max-width: 560px) {
  .bigg-menu-page .collection-card {
    grid-template-columns: 1fr;
    text-align: center;
  }

  .bigg-menu-page .collection-art {
    margin: 0 auto;
  }

  .bigg-menu-page .collection-copy h3::after {
    margin-left: auto;
    margin-right: auto;
  }
}
      .bigg-menu-page .section-title {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 22px;
        margin: 26px 0 22px;
        color: var(--bigg-blue) !important;
        text-align: center;
        font-family: "Oswald", Arial, sans-serif !important;
        font-size: clamp(1.55rem, 3vw, 2.25rem);
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.18em;
      }

      .bigg-menu-page .section-title::before,
      .bigg-menu-page .section-title::after {
        content: "";
        width: min(220px, 18vw);
        border-top: 4px dotted var(--bigg-coral);
      }

      .bigg-menu-page .flavor-list {
        display: block !important;
        overflow: hidden;
        border: 2px solid rgba(234, 96, 95, 0.22);
        border-radius: 20px;
        background: rgba(255, 255, 255, 0.28);
      }

      .bigg-menu-page .flavor-card {
        display: grid !important;
        grid-template-columns: 170px 1fr 185px;
        gap: 28px;
        align-items: center;
        min-height: 124px;
        padding: 18px 24px;
        background: rgba(255, 255, 255, 0.36);
        border-bottom: 2px solid rgba(234, 96, 95, 0.18);
      }

      .bigg-menu-page .flavor-card:last-child {
        border-bottom: 0;
      }

      .bigg-menu-page .flavor-illustration {
        display: flex;
        align-items: center;
        justify-content: center;
        min-height: 92px;
        color: #111 !important;
        font-size: 4.35rem;
        line-height: 1;
        filter: grayscale(1);
      }
.bigg-menu-page .flavor-illustration img {
  width: 96px;
  max-width: 100%;
  height: auto;
  display: block;
  object-fit: contain;
}
      .bigg-menu-page .flavor-content h3 {
        margin: 0 0 6px !important;
        color: var(--bigg-blue) !important;
        font-family: "Pacifico", cursive !important;
        font-size: clamp(1.55rem, 3vw, 2.1rem) !important;
        font-weight: 400 !important;
        line-height: 1.08 !important;
        text-transform: none !important;
        letter-spacing: 0 !important;
      }

      .bigg-menu-page .flavor-content p {
        margin: 0 !important;
        color: var(--bigg-ink) !important;
        font-family: "Nunito", Arial, sans-serif !important;
        font-size: 1.03rem !important;
        font-weight: 800 !important;
        line-height: 1.35 !important;
      }

      .bigg-menu-page .flavor-meta {
        display: flex !important;
        flex-wrap: wrap;
        align-items: center;
        justify-content: flex-end;
        gap: 10px;
      }

      .bigg-menu-page .diet-badge {
        width: 74px;
        height: 74px;
        border: 3px solid var(--bigg-blue);
        border-radius: 999px;
        background: rgba(255, 255, 255, 0.48);
        color: var(--bigg-blue);
        display: inline-flex;
        align-items: center;
        justify-content: center;
        flex-direction: column;
        text-align: center;
        font-family: "Oswald", Arial, sans-serif;
        font-size: 0.54rem;
        font-weight: 700;
        line-height: 1;
        letter-spacing: 0.06em;
        text-transform: uppercase;
      }

      .bigg-menu-page .diet-badge .badge-icon {
        margin-bottom: 4px;
        font-size: 1.08rem;
        line-height: 1;
        filter: grayscale(1);
      }

      .bigg-menu-page .dairy-free-section {
        margin-top: 28px;
        padding: 30px;
        border: 2px solid rgba(154, 134, 164, 0.8);
        border-radius: 22px;
