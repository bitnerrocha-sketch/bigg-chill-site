---
const email = "biggchillmanagment@gmail.com";
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Ice Cream Catering in Cody, WY | The Bigg Chill</title>
    <meta
      name="description"
      content="Bring handcrafted ice cream to your next event with The Bigg Chill’s ice cream catering in Cody, WY. Bulk tubs, pre-scooped servings, cart rental, weddings, birthday parties, and more."
    />

    <link
  href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:ital,wght@0,700;0,800;0,900;1,800;1,900&family=Oswald:wght@400;500;600;700&family=Pacifico&display=swap"
  rel="stylesheet"
/>

    <style>
      :root {
        --teal: #365b6d;
        --coral: #ea605f;
        --cream: #ffece0;
        --cream-light: #fff7ef;
        --pink: #f5c6c8;
        --pink-dark: #f0a1a5;
        --hot-pink: #fe019b;
        --white: #ffffff;
        --black: #000000;
        --shadow: 0 14px 35px rgba(54, 91, 109, 0.12);
      }

      * {
        box-sizing: border-box;
      }

      html {
        scroll-behavior: smooth;
      }

      body {
        margin: 0;
        font-family: "Oswald", sans-serif;
        background: var(--cream);
        color: var(--teal);
      }

      img {
        max-width: 100%;
        display: block;
      }

      a {
        color: inherit;
      }

      .page {
        overflow: hidden;
      }

      /* Header */

      .nav {
  background: var(--cream-light);
  border-bottom: 4px solid var(--coral);
  padding: 6px clamp(18px, 5vw, 76px);
  position: sticky;
  top: 0;
  z-index: 20;
}

.nav-inner {
  width: 100%;
  margin: 0;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24px;
}

.brand {
  text-decoration: none;
  display: inline-flex;
  align-items: center;
  width: 340px;
  height: 135px;
  overflow: hidden;
}

.brand-logo {
  width: 273px;
  height: auto;
  object-fit: contain;
  display: block;
  transform: translateY(10px);
  transform-origin: center;
}

.cup-logo-img {
  width: 230px;
  height: auto;
  display: block;
  transform: rotate(-1deg);
}

.nav-links.open {
  display: flex;
  position: fixed;
  inset: 0;
  z-index: 999;
  background: var(--cream-light);
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 34px;
  padding: 80px 20px;
}

.nav-links.open a {
  font-size: 1.65rem;
  letter-spacing: 9px;
}

.menu-icon.open {
  position: fixed;
  top: 58px;
  right: 32px;
  z-index: 1000;
}

.menu-icon.open span:nth-child(1) {
  transform: translateY(11px) rotate(45deg);
}

.menu-icon.open span:nth-child(2) {
  opacity: 0;
}

.menu-icon.open span:nth-child(3) {
  transform: translateY(-11px) rotate(-45deg);
}
.menu-icon {
  background: transparent;
  border: 0;
  padding: 0;
  cursor: pointer;
}

.nav-links.open a {
  font-family: "Oswald", sans-serif;
  color: var(--teal);
  font-size: 1.45rem;
  font-weight: 400;
  letter-spacing: 9px;
  text-decoration: none;
}

.nav-links.open a.active::after {
  display: none;
}
.nav-links {
  display: flex;
  align-items: center;
  gap: clamp(22px, 3vw, 42px);
}
.nav-links a {
  font-family: "Barlow Condensed", sans-serif;
  color: var(--teal);
  text-decoration: none;
  text-transform: uppercase;
  font-size: 1.1rem;
  font-weight: 900;
  letter-spacing: 1.3px;
  position: relative;
}

.nav-links a:hover {
  color: var(--coral);
}

.nav-links a.active {
  color: var(--coral);
}

.nav-links a.active::after {
  content: "";
  position: absolute;
  left: 0;
  right: 0;
  bottom: -8px;
  height: 3px;
  background: var(--coral);
  border-radius: 999px;
}

      .menu-icon {
        display: none;
        width: 36px;
        height: 26px;
        flex-direction: column;
        justify-content: space-between;
      }

      .menu-icon span {
        height: 4px;
        background: var(--teal);
        border-radius: 999px;
      }

      /* Shared */

      .container {
        width: min(1120px, calc(100% - 40px));
        margin: 0 auto;
      }

      .eyebrow {
        color: var(--coral);
        text-transform: uppercase;
        letter-spacing: 4px;
        font-weight: 700;
        font-size: 0.95rem;
      }

      .script-heading {
        font-family: "Pacifico", cursive;
        color: var(--teal);
        font-weight: 400;
      }

      .section-title {
        color: var(--teal);
        text-transform: uppercase;
        letter-spacing: 6px;
        font-size: clamp(1.7rem, 4vw, 2.6rem);
        line-height: 1.15;
        margin: 0;
      }

      .section-copy {
        font-size: 1.25rem;
        line-height: 1.55;
        margin: 18px auto 0;
        max-width: 780px;
      }

      .btn {
        background: var(--coral);
        color: var(--white);
        padding: 16px 34px;
        text-decoration: none;
        border-radius: 8px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-weight: 700;
        letter-spacing: 2px;
        text-transform: uppercase;
        border: 0;
        cursor: pointer;
        font-family: "Oswald", sans-serif;
        font-size: 1rem;
        transition: transform 0.2s ease, background 0.2s ease;
      }

      .btn:hover {
        background: var(--teal);
        transform: translateY(-2px);
      }

      .wave {
  position: absolute;
  left: 0;
  right: 0;
  bottom: -1px;
  width: 100%;
  height: 110px;
  color: var(--cream-light);
}
.icon-svg {
  width: 54px;
  height: 54px;
  display: block;
  margin: 0 auto 12px;
  color: var(--teal);
}

.card-icon-svg {
  width: 58px;
  height: 58px;
  display: block;
  margin: 0 auto 14px;
  color: var(--teal);
}

.pill-icon {
  width: 22px;
  height: 22px;
  flex-shrink: 0;
  color: var(--coral);
}

.lead-svg {
  width: 76px;
  height: 76px;
  color: var(--cream);
  display: block;
  margin: 0 auto;
}

.doodle-svg {
  width: 90px;
  height: 90px;
  color: var(--teal);
  display: block;
  margin: 0 auto;
  opacity: 0.85;
}
      /* Hero */

      .hero {
  position: relative;
  background:
    linear-gradient(rgba(245, 198, 200, 0.48), rgba(245, 198, 200, 0.48)),
    url("/sprinkles-bg.png") center / cover no-repeat,
    linear-gradient(110deg, var(--pink) 0%, #ffd7df 55%, #f8d1d5 100%);
  padding: 86px 0 120px;
}

      .hero-grid {
        display: grid;
        grid-template-columns: 1.05fr 0.95fr;
        align-items: center;
        gap: 48px;
      }
      .hero h1 {
        color: var(--teal);
        font-size: clamp(3rem, 7vw, 5.8rem);
        line-height: 0.95;
        margin: 14px 0 22px;
        text-transform: uppercase;
        letter-spacing: 6px;
        font-weight: 700;
      }

      .hero p {
        max-width: 560px;
        font-size: 1.35rem;
        line-height: 1.35;
        margin: 0 0 26px;
        font-weight: 500;
      }

      .lead-note {
        display: flex;
        align-items: center;
        gap: 8px;
        margin-top: 16px;
        font-size: 0.95rem;
        font-weight: 600;
      }

      .hero-visual {
        position: relative;
        min-height: 420px;
        display: flex;
        align-items: center;
        justify-content: center;
      }

      .ice-cream-scene {
        position: relative;
        width: min(460px, 100%);
        aspect-ratio: 1 / 0.9;
      }
.product-cup-img {
  width: 500px;
  height: auto;
  display: block;
  margin: 0 auto;
  transform: translate(-35px, -24px);
  filter: drop-shadow(0 18px 32px rgba(54, 91, 109, 0.18));
}
      .cup {
        position: absolute;
        right: 40px;
        bottom: 40px;
        width: 280px;
        height: 220px;
        background:
          repeating-linear-gradient(
            90deg,
            #fff5f5 0 22px,
            #f5a7af 22px 42px
          );
        border: 6px solid #fff8f1;
        border-radius: 25px 25px 90px 90px;
        box-shadow: 0 18px 40px rgba(54, 91, 109, 0.18);
        display: flex;
        align-items: center;
        justify-content: center;
        text-align: center;
      }
      .scoop {
        position: absolute;
        border-radius: 50%;
        box-shadow: inset -12px -12px 20px rgba(54, 91, 109, 0.08);
      }

      .scoop.chocolate {
        width: 145px;
        height: 145px;
        background: #6d3d28;
        left: 110px;
        top: 22px;
      }

      .scoop.vanilla {
        width: 150px;
        height: 150px;
        background: #fff2d5;
        right: 42px;
        top: 18px;
      }

      .scoop.strawberry {
        width: 150px;
        height: 150px;
        background: #f0a1a5;
        left: 170px;
        top: 58px;
        z-index: 2;
      }

      .cone {
        position: absolute;
        right: -10px;
        bottom: 65px;
        width: 120px;
        height: 180px;
        background:
          linear-gradient(45deg, transparent 45%, rgba(130, 75, 30, 0.35) 46%, rgba(130, 75, 30, 0.35) 52%, transparent 53%),
          linear-gradient(-45deg, transparent 45%, rgba(130, 75, 30, 0.35) 46%, rgba(130, 75, 30, 0.35) 52%, transparent 53%),
          #d4883e;
        background-size: 28px 28px;
        clip-path: polygon(50% 100%, 0 0, 100% 0);
        transform: rotate(58deg);
        border-radius: 14px;
      }

      .scooper {
        position: absolute;
        left: 35px;
        bottom: 75px;
        width: 170px;
        height: 34px;
        background: #f0a1a5;
        border-radius: 999px;
        transform: rotate(-25deg);
      }

      .scooper::before {
        content: "";
        position: absolute;
        width: 82px;
        height: 82px;
        border-radius: 50%;
        background: radial-gradient(circle at 35% 35%, #ffffff, #a8a8a8 45%, #6f6f6f);
        left: -54px;
        top: -24px;
        border: 4px solid #e6e6e6;
      }

      .melt {
        position: absolute;
        left: 88px;
        bottom: 42px;
        width: 110px;
        height: 32px;
        background: #f0a1a5;
        border-radius: 50%;
        opacity: 0.9;
      }

      /* Intro */

      .intro {
        background: var(--cream-light);
        padding: 52px 0 34px;
        text-align: center;
      }

      .intro h2 {
        font-size: clamp(1.9rem, 4vw, 3rem);
        margin: 0;
      }

      .sparkle {
        color: var(--coral);
        margin: 0 18px;
        font-family: "Oswald", sans-serif;
      }

      /* How It Works */

      .steps-section {
        background: var(--cream-light);
        padding: 22px 0 64px;
        text-align: center;
      }

      .steps {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 26px;
        margin-top: 30px;
      }

      .step-card {
        position: relative;
        background: rgba(245, 198, 200, 0.48);
        border: 2px solid rgba(234, 96, 95, 0.15);
        border-radius: 22px;
        padding: 34px 18px 24px;
        box-shadow: var(--shadow);
        min-height: 175px;
      }

      .step-number {
        position: absolute;
        top: -18px;
        left: 18px;
        width: 44px;
        height: 44px;
        border-radius: 50%;
        background: var(--coral);
        color: white;
        display: grid;
        place-items: center;
        font-size: 1.4rem;
        font-weight: 700;
      }

      .step-icon {
        font-size: 2.8rem;
        margin-bottom: 8px;
      }

      .step-card h3 {
        margin: 0;
        font-size: 1.2rem;
        line-height: 1.15;
      }

      /* Pricing */

      .pricing {
        background: linear-gradient(180deg, var(--cream-light) 0%, var(--cream) 100%);
        padding: 20px 0 54px;
        text-align: center;
      }

      .pricing-header {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 22px;
        margin-bottom: 28px;
      }

      .pricing-header::before,
      .pricing-header::after {
        content: "";
        width: 80px;
        height: 2px;
        background: var(--coral);
        opacity: 0.55;
      }

      .pricing-grid {
        display: grid;
        grid-template-columns: repeat(5, 1fr);
        gap: 16px;
      }

      .pricing-card {
        background: rgba(255, 255, 255, 0.38);
        border: 2px solid rgba(234, 96, 95, 0.22);
        border-radius: 22px;
        padding: 26px 18px;
        text-align: left;
        box-shadow: var(--shadow);
        position: relative;
      }

      .pricing-card.featured {
        background: rgba(245, 198, 200, 0.65);
        border-color: rgba(234, 96, 95, 0.45);
      }

      .ribbon {
        position: absolute;
        top: -16px;
        left: 50%;
        transform: translateX(-50%);
        background: var(--coral);
        color: white;
        padding: 6px 18px;
        border-radius: 999px;
        font-size: 0.75rem;
        letter-spacing: 1px;
        font-weight: 700;
        text-transform: uppercase;
        white-space: nowrap;
      }

      .card-icon {
        font-size: 3rem;
        text-align: center;
        margin-bottom: 12px;
      }

      .pricing-card h3 {
        color: var(--teal);
        text-align: center;
        margin: 0 0 10px;
        font-size: 1.75rem;
        line-height: 0.95;
      }

      .best-for {
        text-align: center;
        font-size: 0.98rem;
        line-height: 1.25;
        margin: 0 0 18px;
        font-weight: 500;
      }

      .pricing-card ul {
        margin: 0;
        padding-left: 18px;
        font-size: 0.97rem;
        line-height: 1.35;
      }

      .pricing-card li {
        margin-bottom: 8px;
      }

      .price-highlight {
        color: var(--coral);
        font-size: 1.6rem;
        text-align: center;
        margin: 16px 0 0;
        font-weight: 700;
      }

      /* Add-ons */

      .addons {
        background: var(--cream);
        padding: 14px 0 58px;
        text-align: center;
      }

      .addons h2 {
        color: var(--coral);
        font-size: 1.25rem;
        letter-spacing: 5px;
        text-transform: uppercase;
        margin: 0 0 24px;
      }

      .addon-pills {
        display: flex;
        flex-wrap: wrap;
        justify-content: center;
        gap: 14px;
      }

      .pill {
        background: rgba(255, 255, 255, 0.42);
        border: 2px solid rgba(54, 91, 109, 0.13);
        border-radius: 16px;
        padding: 12px 18px;
        min-width: 130px;
        font-size: 0.95rem;
        font-weight: 600;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
      }

      /* Lead Time */

      .lead-time {
        background: var(--teal);
        color: var(--cream);
        padding: 38px 0;
      }

      .lead-inner {
        display: grid;
        grid-template-columns: 90px 1fr 90px;
        align-items: center;
        gap: 28px;
      }

      .lead-icon {
        font-size: 3.5rem;
        text-align: center;
      }

      .lead-time h2 {
        margin: 0 0 8px;
        color: var(--cream);
        letter-spacing: 5px;
        text-transform: uppercase;
        font-size: clamp(1.4rem, 3vw, 2.2rem);
      }

      .lead-time p {
        margin: 0;
        font-size: 1.15rem;
        line-height: 1.4;
      }

      /* Service Area + FAQ */

      .service-area {
        background: var(--cream-light);
        padding: 48px 0 36px;
      }

      .service-grid {
        display: grid;
        grid-template-columns: 120px 1fr 150px;
        align-items: center;
        gap: 28px;
      }

      .doodle {
        font-size: 4rem;
        text-align: center;
        opacity: 0.85;
      }

      .service-area h2 {
        font-size: clamp(1.8rem, 4vw, 2.8rem);
        margin: 0 0 10px;
      }

      .service-area p {
        margin: 0;
        font-size: 1.15rem;
        line-height: 1.45;
        font-weight: 500;
      }

      .faq {
        background: var(--cream-light);
        padding: 10px 0 56px;
      }

      .faq-list {
        max-width: 1000px;
        margin: 0 auto;
        display: grid;
        gap: 8px;
      }

      details {
        background: rgba(255, 255, 255, 0.5);
        border: 1px solid rgba(54, 91, 109, 0.18);
        border-radius: 10px;
        padding: 0;
      }

      summary {
        cursor: pointer;
        list-style: none;
        padding: 14px 18px;
        font-weight: 600;
        display: flex;
        align-items: center;
        justify-content: space-between;
      }

      summary::-webkit-details-marker {
        display: none;
      }

      summary::after {
        content: "+";
        font-size: 1.4rem;
        color: var(--teal);
      }

      details[open] summary::after {
        content: "–";
      }

      details p {
        padding: 0 18px 16px;
        margin: 0;
        line-height: 1.4;
      }

      /* Quote Form */

      .quote {
        background: var(--pink);
        padding: 54px 0 70px;
      }

      .quote-card {
        background: var(--cream-light);
        border-radius: 26px;
        padding: 36px;
        box-shadow: var(--shadow);
      }

      .quote h2 {
        text-align: center;
        margin-bottom: 28px;
      }

      .form-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 14px;
      }

      .form-field,
      .form-message,
      .form-select {
        width: 100%;
        border: 1px solid rgba(54, 91, 109, 0.25);
        border-radius: 8px;
        padding: 13px 14px;
        font-family: "Oswald", sans-serif;
        color: var(--teal);
        background: white;
        font-size: 1rem;
      }

      .form-select {
        grid-column: 1 / -1;
      }

      .form-message {
        grid-column: 1 / -1;
        min-height: 110px;
        resize: vertical;
      }

      .quote-actions {
        text-align: center;
        margin-top: 18px;
      }

      .form-note {
        text-align: center;
        margin: 14px 0 0;
        font-size: 0.92rem;
        color: rgba(54, 91, 109, 0.8);
      }
.site-footer {
  background: var(--teal);
  color: var(--cream-light);
  text-align: center;
  padding: 22px 20px;
  font-size: 1rem;
  font-weight: 600;
  letter-spacing: 0.4px;
}

.site-footer p {
  margin: 0;
}
      /* Mobile */

      @media (max-width: 980px) {
        .nav-links {
          display: none;
        }

        .menu-icon {
          display: flex;
        }

        .hero {
          padding: 58px 0 92px;
        }

        .hero-grid {
          grid-template-columns: 1fr;
          text-align: left;
          gap: 28px;
        }

        .hero-visual {
          min-height: 310px;
        }

        .ice-cream-scene {
          width: min(410px, 100%);
          margin: 0 auto;
        }

        .steps {
          grid-template-columns: repeat(2, 1fr);
        }

        .pricing-grid {
          grid-template-columns: repeat(2, 1fr);
        }

        .pricing-card.featured {
          grid-column: span 2;
        }

        .service-grid {
          grid-template-columns: 1fr;
          text-align: center;
        }

        .lead-inner {
          grid-template-columns: 1fr;
          text-align: center;
        }

        .form-grid {
          grid-template-columns: 1fr;
        }
      }

  @media (max-width: 620px) {
  .container {
    width: min(100% - 28px, 1120px);
  }

  .nav {
    padding: 14px 16px;
  }

  .brand-logo {
    width: 300px;
  }

  .cup-logo-img {
    width: 135px;
  }

  .hero h1 {
    letter-spacing: 4px;
  }
        .hero p {
          font-size: 1.08rem;
        }

        .cup {
          width: 230px;
          height: 180px;
          right: 24px;
        }
        .scoop.chocolate {
          width: 118px;
          height: 118px;
          left: 74px;
        }

        .scoop.vanilla {
          width: 120px;
          height: 120px;
          right: 36px;
        }

        .scoop.strawberry {
          width: 126px;
          height: 126px;
          left: 126px;
        }

        .cone {
          width: 90px;
          height: 140px;
          right: 0;
          bottom: 50px;
        }

        .scooper {
          left: 34px;
          bottom: 54px;
          width: 130px;
        }

        .steps,
        .pricing-grid {
          grid-template-columns: 1fr;
        }

        .pricing-card.featured {
          grid-column: auto;
        }

        .pricing-header::before,
        .pricing-header::after {
          display: none;
        }

        .section-title {
          letter-spacing: 4px;
        }

        .quote-card {
          padding: 26px 18px;
        }
      }
    </style>
  </head>

  <body>
    <div class="page">
      <nav class="nav">
        <div class="nav-inner">
          <a href="/" class="brand" aria-label="The Bigg Chill home">
  <img
    src="/logo-transparent.png"
    alt="The Bigg Chill Handcrafted Ice Cream"
    class="brand-logo"
  />
</a>
          <div class="nav-links" id="navLinks">
  <a href="/">Home</a>
  <a href="/menu">Menu</a>
  <a href="/catering" class="active">Catering</a>
  <a href="https://app.squareup.com/gift/MLQY19DJP25AS/order" target="_blank">Gift Cards</a>
</div>

          <button class="menu-icon" id="menuToggle" aria-label="Open menu" type="button">
            <span></span>
