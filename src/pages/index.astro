    <script>
      const menuToggle = document.getElementById("menuToggle");
      const mobileMenu = document.getElementById("mobileMenu");
      const closeMenu = document.getElementById("closeMenu");

      menuToggle?.addEventListener("click", () => {
        mobileMenu.classList.add("open");
      });

      closeMenu?.addEventListener("click", () => {
        mobileMenu.classList.remove("open");
      });

      const heroSlides = [
        {
          label: "Featured Flavor",
          flavor: "Strawberry Cheesecake",
          note: "Creamy, fruity & oh-so dreamy.",
        },
        {
          label: "Small-Batch Favorite",
          flavor: "Cookie Dough",
          note: "A classic scoop made the Bigg Chill way.",
        },
        {
          label: "Rotating Monthly",
          flavor: "Seasonal Scoops",
          note: "New flavors worth coming back for.",
        },
        {
          label: "Made In Cody",
          flavor: "Handcrafted Ice Cream",
          note: "Fresh, thoughtful, and made with care.",
        },
        {
          label: "Fan Favorite",
          flavor: "Bigg Chill Classics",
          note: "The flavors people ask for again and again.",
        },
      ];

      const slides = Array.from(document.querySelectorAll(".hero-slide"));
      const dots = Array.from(document.querySelectorAll(".hero-dot"));
      const label = document.getElementById("slideLabel");
      const prev = document.getElementById("prevSlide");
      const next = document.getElementById("nextSlide");

      let activeSlide = 0;
      let slideTimer;

      function showSlide(index) {
        activeSlide = (index + slides.length) % slides.length;

        slides.forEach((slide, slideIndex) => {
          slide.classList.toggle("active", slideIndex === activeSlide);
        });

        dots.forEach((dot, dotIndex) => {
          dot.classList.toggle("active", dotIndex === activeSlide);
        });

        const current = heroSlides[activeSlide];

        if (label && current) {
          label.innerHTML = `
            <small>${current.label}</small>
            <strong>${current.flavor}</strong>
            <span>${current.note}</span>
          `;
        }
      }

      function startSlider() {
        slideTimer = window.setInterval(() => {
          showSlide(activeSlide + 1);
        }, 5000);
      }

      function resetSlider() {
        window.clearInterval(slideTimer);
        startSlider();
      }

      prev?.addEventListener("click", () => {
        showSlide(activeSlide - 1);
        resetSlider();
      });

      next?.addEventListener("click", () => {
        showSlide(activeSlide + 1);
        resetSlider();
      });

      dots.forEach((dot) => {
        dot.addEventListener("click", () => {
          const index = Number(dot.getAttribute("data-dot"));
          showSlide(index);
          resetSlider();
        });
      });

      startSlider();
    </script>
